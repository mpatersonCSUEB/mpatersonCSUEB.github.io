# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# SESSION_SECRET must be a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Port the Express server listens on.
PORT=3000

# Environment: development | production
# In production, the server will refuse to start if SESSION_SECRET is missing.
NODE_ENV=development

# TMDb (The Movie Database) API key. Optional — required only for the TMDb
# search + import feature. Get a free key at:
#   https://www.themoviedb.org/settings/api
# When this is blank, /api/tmdb/* returns 503 and the rest of the app still works.
TMDB_API_KEY=
